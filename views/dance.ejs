<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PETOI - Dance Coordinator</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/dance.css">
</head>
<body>
  <header>
    <h1>Dance Coordinator</h1>
    <div>
      <a href="/stream" class="btn-nav">Stream</a>
      <a href="/" class="btn-nav">Dashboard</a>
      <a href="/auth/logout" class="btn-logout">Logout</a>
    </div>
  </header>
  
  <main class="dance-container">
    <section class="robots-grid">
      <h2>Robot Status</h2>
      <p style="opacity: 0.7; margin-bottom: 1rem;">Click on a robot to select it</p>
      <div id="robots-list"></div>
    </section>
    
    <section class="commands-panel">
      <h2>Set Action</h2>
      
      <div class="form-group">
        <label>Select Robots:</label>
        <div id="robot-selectors"></div>
        <button onclick="selectAll()" class="btn-small">Select All</button>
        <button onclick="selectNone()" class="btn-small">Select None</button>
      </div>
      
      <div class="form-group">
        <label for="action">Action:</label>
        <select id="action">
          <option value="idle">Idle</option>
        </select>
      </div>
      
      <button onclick="setAction()" class="btn">Set Action (Selected)</button>
      <button onclick="setActionAll()" class="btn btn-secondary">Set Action (All)</button>
      <button onclick="clearActions()" class="btn btn-danger">Reset All to Idle</button>
    </section>
    
    <section class="custom-panel">
      <h2>Custom Actions per Robot</h2>
      <p style="opacity: 0.7; margin-bottom: 1rem;">Set different actions for each robot</p>
      <div id="custom-actions"></div>
      <button onclick="setCustomActions()" class="btn" style="margin-top: 1rem;">Apply Custom Actions</button>
    </section>
    
    <section class="commands-config-panel">
      <h2>Configure Commands</h2>
      <p style="opacity: 0.7; margin-bottom: 1rem;">Edit the PETOI command string for each action</p>
      <table class="commands-table">
        <thead>
          <tr>
            <th>Action Name</th>
            <th>PETOI Command</th>
            <th>Save</th>
          </tr>
        </thead>
        <tbody id="commands-table-body">
        </tbody>
      </table>
    </section>
  </main>
  
  <script src="/js/dance.js"></script>
</body>
</html>

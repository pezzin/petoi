<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PETOI - Dashboard</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <h1>PETOI Dashboard</h1>
    <div>
      <a href="/stream" class="btn-nav">Stream</a>
      <a href="/dance" class="btn-nav">Dance</a>
      <a href="/backgrounds" class="btn-nav">Sfondi</a>
      <a href="/auth/logout" class="btn-logout">Logout</a>
    </div>
  </header>
  
  <main>
    <section class="messages-card full-width">
      <h2>Messaggi dal Robot</h2>
      <button id="clear-messages" class="btn-small">Cancella tutti</button>
      <div id="messages-container">
        <div class="message-empty">Nessun messaggio</div>
      </div>
    </section>
    
    <section class="status-card">
      <h2>Status</h2>
      <div id="status">Caricamento...</div>
    </section>
    
    <section class="data-card">
      <h2>Dati Sensori</h2>
      <div id="sensor-data">Nessun dato</div>
    </section>
    
    <section class="control-card">
      <h2>Controlli PETOI</h2>
      <p>Aggiungi qui i controlli per il robot</p>
    </section>
  </main>
  
  <script src="/js/app.js"></script>
</body>
</html>

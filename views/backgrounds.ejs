<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PETOI - Sfondi Scenografia</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <h1>Sfondi Scenografia</h1>
    <div>
      <a href="/sfondo" class="btn-nav" target="_blank">Apri Pagina Sfondo</a>
      <a href="/" class="btn-nav">Dashboard</a>
      <a href="/auth/logout" class="btn-logout">Logout</a>
    </div>
  </header>
  
  <p style="text-align: center; opacity: 0.7; margin: 1rem 2rem;">
    Seleziona uno sfondo. La pagina <a href="/sfondo" target="_blank">/sfondo</a> si aggiornerà automaticamente.
  </p>
  
  <main class="backgrounds-grid">
    <div class="bg-card" data-bg="dracula" onclick="setBackground('dracula')">
      <div class="bg-preview">
        <img src="/images/dracula.jpg" alt="Dracula">
      </div>
      <h3>Dracula</h3>
      <p>Tema gotico</p>
    </div>
    
    <div class="bg-card" data-bg="frankestein" onclick="setBackground('frankestein')">
      <div class="bg-preview">
        <img src="/images/frankestein.png" alt="Frankestein">
      </div>
      <h3>Frankenstein</h3>
      <p>Tema mostruoso</p>
    </div>
    
    <div class="bg-card" data-bg="piramidi" onclick="setBackground('piramidi')">
      <div class="bg-preview">
        <img src="/images/piramidi.jpg" alt="Piramidi">
      </div>
      <h3>Piramidi</h3>
      <p>Tema egizio</p>
    </div>
    
    <div class="bg-card" data-bg="vangogh" onclick="setBackground('vangogh')">
      <div class="bg-preview">
        <img src="/images/vangogh.png" alt="Van Gogh">
      </div>
      <h3>Van Gogh</h3>
      <p>Tema artistico</p>
    </div>
  </main>
  
  <div id="current-bg" class="current-indicator">
    Sfondo attuale: <span id="bg-name">Caricamento...</span>
  </div>
  
  <script>
    let currentBg = 'dracula';
    
    async function loadCurrentBackground() {
      try {
        const res = await fetch('/api/background');
        const data = await res.json();
        currentBg = data.background;
        updateIndicator();
      } catch (err) {
        console.error('Errore:', err);
      }
    }
    
    async function setBackground(bg) {
      try {
        await fetch('/api/background', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ background: bg })
        });
        currentBg = bg;
        updateIndicator();
        flashCard(bg);
      } catch (err) {
        console.error('Errore:', err);
      }
    }
    
    function updateIndicator() {
      const names = {
        'dracula': 'Dracula',
        'frankestein': 'Frankenstein',
        'piramidi': 'Piramidi',
        'vangogh': 'Van Gogh'
      };
      document.getElementById('bg-name').textContent = names[currentBg] || currentBg;
      
      document.querySelectorAll('.bg-card').forEach(card => {
        card.classList.toggle('active', card.dataset.bg === currentBg);
      });
    }
    
    function flashCard(bg) {
      const card = document.querySelector(`.bg-card[data-bg="${bg}"]`);
      if (card) {
        card.style.transform = 'scale(1.05)';
        setTimeout(() => card.style.transform = '', 200);
      }
    }
    
    loadCurrentBackground();
  </script>
</body>
</html>
